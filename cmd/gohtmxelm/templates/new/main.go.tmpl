package main

import (
	"log"
	"net/http"
	"os"
	"sync"

	"github.com/go-chi/chi/v5"
	"github.com/go-chi/chi/v5/middleware"

	"github.com/nkhine/gohtmxelm"
)

// counter is the server-owned state every surface converges on. Go owns it; the
// browser only ever renders what the server pushes over the SSE stream.
type counter struct {
	mu     sync.Mutex
	value  int
	events *gohtmxelm.Broadcaster[int]
}

func newCounter() *counter {
	return &counter{events: gohtmxelm.NewBroadcaster[int](16)}
}

func (c *counter) snapshot() int {
	c.mu.Lock()
	defer c.mu.Unlock()
	return c.value
}

func (c *counter) bump() {
	c.mu.Lock()
	c.value++
	v := c.value
	c.mu.Unlock()
	c.events.Publish(v)
}

func main() {
	count := newCounter()

	kit := gohtmxelm.New(gohtmxelm.Options{
		AssetPath: "/gohtmxelm",
		Sources: []gohtmxelm.Source{
			{URL: "/api/stream", Events: []string{"count"}},
		},
	})

	r := chi.NewRouter()
	r.Use(middleware.Logger)

	// Embedded broker runtime (gohtmxelm-broker.js).
	r.Handle("/gohtmxelm/*", http.StripPrefix("/gohtmxelm/", kit.Assets()))
	// Compiled Elm bundle (window.Elm.Counter) plus any other static assets.
	r.Handle("/static/*", http.StripPrefix("/static/", http.FileServer(http.Dir("static"))))

	r.Get("/", func(w http.ResponseWriter, req *http.Request) {
		// ElmIsland renders the mount point; the broker hydrates it from
		// window.Elm.Counter once the page and runtime have loaded.
		island, err := gohtmxelm.ElmIsland("counter", "Counter", map[string]any{})
		if err != nil {
			http.Error(w, err.Error(), http.StatusInternalServerError)
			return
		}
		w.Header().Set("Content-Type", "text/html; charset=utf-8")
		_ = Page(kit.BrowserScript(), island).Render(req.Context(), w)
	})

	// One SSE stream carries every broker event. Serve subscribes, sends the
	// current snapshot once, then forwards each published value until the
	// client disconnects.
	r.Get("/api/stream", func(w http.ResponseWriter, req *http.Request) {
		stream, err := gohtmxelm.NewStream(w, req)
		if err != nil {
			http.Error(w, err.Error(), http.StatusInternalServerError)
			return
		}
		_ = gohtmxelm.Serve(stream, count.events,
			func(s *gohtmxelm.Stream) error {
				return s.Send("count", map[string]int{"value": count.snapshot()})
			},
			func(s *gohtmxelm.Stream, v int) error {
				return s.Send("count", map[string]int{"value": v})
			},
		)
	})

	// The +1 button posts here; Go mutates state and broadcasts to every stream.
	r.Post("/api/bump", func(w http.ResponseWriter, req *http.Request) {
		count.bump()
		gohtmxelm.NoContent(w)
	})

	addr := ":" + port()
	log.Printf("listening on http://localhost%s", addr)
	if err := http.ListenAndServe(addr, r); err != nil {
		log.Fatal(err)
	}
}

func port() string {
	if p := os.Getenv("PORT"); p != "" {
		return p
	}
	return "8080"
}
