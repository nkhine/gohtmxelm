# syntax=docker/dockerfile:1

FROM golang:1.25 AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /out/server .

# distroless static: a tiny, non-root final image. The minimal scaffold embeds
# its page as a string, so no extra runtime files are needed.
FROM gcr.io/distroless/static-debian12:nonroot
WORKDIR /app
COPY --from=build /out/server ./server
# SSE works straight from the Go server — it sets the streaming headers
# (including X-Accel-Buffering: no) and flushes every event. If you front this
# with a reverse proxy, disable response buffering or streaming will break.
ENV PORT=8080
EXPOSE 8080
USER nonroot:nonroot
ENTRYPOINT ["./server"]
